{
  "name": "ctb-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "dev:api": "pnpm --filter @ctb/api start",
    "dev:web": "pnpm --filter @ctb/web start",
    "dev:simulator-worker": "pnpm --filter @ctb/simulator-worker start",
    "dev:reporting-worker": "pnpm --filter @ctb/reporting-worker start",
    "dev:notification-worker": "pnpm --filter @ctb/notification-worker start",
    "dev:stack:up": "docker compose -f infra/docker/compose.yml up --build",
    "dev:stack:down": "docker compose -f infra/docker/compose.yml down --volumes",
    "dev:stack:logs": "docker compose -f infra/docker/compose.yml logs -f",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:validate": "prisma validate",
    "db:prepare": "pnpm db:generate && pnpm db:migrate:deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:conventions": "node scripts/check-package-conventions.mjs",
    "seed:runtime-heartbeat": "node scripts/seed-runtime-heartbeat.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:integration": "pnpm db:generate && node --import tsx --test tests/**/*.integration.ts",
    "validate": "pnpm package:conventions && pnpm lint && pnpm typecheck && pnpm test && pnpm format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.0.15",
    "prisma": "^6.7.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0"
  }
}
