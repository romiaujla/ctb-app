generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

enum SimulationAccountStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum SimulatedOrderSide {
  BUY
  SELL
}

enum SimulatedOrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
}

enum SimulatedOrderStatus {
  ACCEPTED
  PARTIALLY_FILLED
  FILLED
  CANCELED
  REJECTED
}

enum SimulatorEventType {
  TRADE_INTENT_ACCEPTED
  TRADE_INTENT_REJECTED
  ORDER_SUBMITTED
  ORDER_PARTIALLY_FILLED
  ORDER_FILLED
  ORDER_CANCELED
  POSITION_REVALUED
  PORTFOLIO_SNAPSHOTTED
  ACCOUNT_ADJUSTED
}

enum MarketDataIngestMode {
  POLL
  SUBSCRIPTION
  MANUAL
}

enum MarketDataIngestStatus {
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum MarketDataEventType {
  QUOTE
  TRADE
  BAR
  STATUS
}

enum MarketDataSessionState {
  PRE_MARKET
  REGULAR
  AFTER_HOURS
  CLOSED
}

enum MarketDataQuality {
  VALID
  PARTIAL
  STALE
  INVALID
}

enum MarketDataFreshnessState {
  READY
  DELAYED
  STALE
  PARTIAL
  INVALID
  UNAVAILABLE
}

enum MarketDataIngestDecisionType {
  ACCEPTED
  DUPLICATE
  REJECTED
}

enum StrategyDecisionState {
  TRADE_INTENT_EMITTED
  SKIPPED
  BLOCKED
  INVALID_INPUT
}

model RuntimeHeartbeat {
  id        String   @id @default(cuid())
  service   String
  startedAt DateTime
  createdAt DateTime @default(now())
}

model MarketDataIngestRun {
  id                   String                     @id
  provider             String
  ingestMode           MarketDataIngestMode
  status               MarketDataIngestStatus
  adapterVersion       String
  startedAt            DateTime
  completedAt          DateTime?
  requestedInstruments Json
  notes                String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  rawRecords           RawMarketDataRecord[]
  canonicalEvents      MarketDataEvent[]
  ingestDecisions      MarketDataIngestDecision[]

  @@index([provider, startedAt])
  @@index([status, startedAt])
}

model RawMarketDataRecord {
  id                String                    @id
  ingestRunId       String
  provider          String
  providerSymbol    String?
  providerEventId   String?
  receivedTimestamp DateTime
  providerTimestamp DateTime?
  adapterVersion    String
  payload           Json
  createdAt         DateTime                  @default(now())
  ingestRun         MarketDataIngestRun       @relation(fields: [ingestRunId], references: [id], onDelete: Restrict)
  canonicalEvents   MarketDataEvent[]
  ingestDecisions   MarketDataIngestDecision[]

  @@index([ingestRunId, receivedTimestamp])
  @@index([provider, providerEventId])
}

model MarketDataEvent {
  id                   String                    @id
  eventId              String                    @unique
  ingestRunId          String
  rawRecordId          String?
  eventType            MarketDataEventType
  instrumentId         String
  symbol               String
  provider             String
  providerEventId      String?
  providerTimestamp    DateTime
  observedTimestamp    DateTime
  normalizedTimestamp  DateTime
  sessionState         MarketDataSessionState
  quality              MarketDataQuality
  freshnessState       MarketDataFreshnessState
  sourceLatencyMs      Int?
  rawReference         String?
  normalizationVersion String
  payload              Json
  persistedTimestamp   DateTime
  createdAt            DateTime                  @default(now())
  ingestRun            MarketDataIngestRun       @relation(fields: [ingestRunId], references: [id], onDelete: Restrict)
  rawRecord            RawMarketDataRecord?      @relation(fields: [rawRecordId], references: [id], onDelete: SetNull)
  ingestDecisions      MarketDataIngestDecision[]

  @@index([instrumentId, normalizedTimestamp])
  @@index([eventType, normalizedTimestamp])
  @@index([ingestRunId, normalizedTimestamp])
  @@index([provider, providerEventId])
}

model MarketDataIngestDecision {
  id             String                       @id
  ingestRunId    String
  rawRecordId    String?
  marketDataEventId String?
  decisionType   MarketDataIngestDecisionType
  duplicateKey   String?
  rejectionReason String?
  freshnessState MarketDataFreshnessState?
  quality        MarketDataQuality?
  decidedTimestamp DateTime
  createdAt      DateTime                     @default(now())
  ingestRun      MarketDataIngestRun          @relation(fields: [ingestRunId], references: [id], onDelete: Restrict)
  rawRecord      RawMarketDataRecord?         @relation(fields: [rawRecordId], references: [id], onDelete: SetNull)
  marketDataEvent MarketDataEvent?            @relation(fields: [marketDataEventId], references: [id], onDelete: SetNull)

  @@index([ingestRunId, decidedTimestamp])
  @@index([decisionType, decidedTimestamp])
  @@index([duplicateKey])
}

model SimulationAccount {
  id                   String                  @id
  baseCurrency         String
  startingBalance      Decimal                 @db.Decimal(20, 8)
  currentCashBalance   Decimal                 @db.Decimal(20, 8)
  status               SimulationAccountStatus
  createdTimestamp     DateTime
  configurationVersion String
  updatedAt            DateTime                @updatedAt
  orders               SimulatedOrder[]
  fills                SimulatedFill[]
  events               SimulatorEvent[]
  positions            Position[]
  portfolios           Portfolio[]
  portfolioSnapshots   PortfolioSnapshot[]
}

model SimulatedOrder {
  id                    String               @id
  simulationAccountId   String
  tradeIntentId         String
  instrumentId          String
  side                  SimulatedOrderSide
  orderType             SimulatedOrderType
  requestedQuantity     Decimal              @db.Decimal(20, 8)
  acceptedQuantity      Decimal              @db.Decimal(20, 8)
  status                SimulatedOrderStatus
  submittedTimestamp    DateTime
  executionModelVersion String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  simulationAccount     SimulationAccount    @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)
  fills                 SimulatedFill[]

  @@index([simulationAccountId])
  @@index([simulationAccountId, status])
  @@index([tradeIntentId])
}

model SimulatedFill {
  id                  String            @id
  simulatedOrderId    String
  simulationAccountId String
  instrumentId        String
  fillQuantity        Decimal           @db.Decimal(20, 8)
  fillPrice           Decimal           @db.Decimal(20, 8)
  simulatedFeeAmount  Decimal           @db.Decimal(20, 8)
  slippageAmount      Decimal           @db.Decimal(20, 8)
  fillTimestamp       DateTime
  createdAt           DateTime          @default(now())
  simulatedOrder      SimulatedOrder    @relation(fields: [simulatedOrderId], references: [id], onDelete: Restrict)
  simulationAccount   SimulationAccount @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)

  @@index([simulatedOrderId])
  @@index([simulationAccountId, fillTimestamp])
  @@index([simulationAccountId, instrumentId])
}

model SimulatorEvent {
  id                  String            @id
  simulationAccountId String
  eventType           SimulatorEventType
  eventTimestamp      DateTime
  recordedTimestamp   DateTime
  sequenceKey         String
  correlationId       String?
  causationId         String?
  schemaVersion       Int
  payload             Json
  createdAt           DateTime          @default(now())
  simulationAccount   SimulationAccount @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)
  portfolioSnapshots  PortfolioSnapshot[]

  @@unique([simulationAccountId, sequenceKey])
  @@index([simulationAccountId, eventType, eventTimestamp])
}

model Position {
  id                  String            @id
  simulationAccountId String
  instrumentId        String
  quantity            Decimal           @db.Decimal(20, 8)
  averageEntryCost    Decimal           @db.Decimal(20, 8)
  marketValue         Decimal           @db.Decimal(20, 8)
  realizedPnl         Decimal           @db.Decimal(20, 8)
  unrealizedPnl       Decimal           @db.Decimal(20, 8)
  lastUpdatedTimestamp DateTime
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  simulationAccount   SimulationAccount @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)

  @@unique([simulationAccountId, instrumentId])
}

model Portfolio {
  id                  String            @id
  simulationAccountId String
  netLiquidationValue Decimal           @db.Decimal(20, 8)
  grossExposure       Decimal           @db.Decimal(20, 8)
  realizedPnl         Decimal           @db.Decimal(20, 8)
  unrealizedPnl       Decimal           @db.Decimal(20, 8)
  valuationTimestamp  DateTime
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  simulationAccount   SimulationAccount @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)

  @@unique([simulationAccountId])
}

model PortfolioSnapshot {
  id                  String            @id
  simulationAccountId String
  cashBalance         Decimal           @db.Decimal(20, 8)
  grossExposure       Decimal           @db.Decimal(20, 8)
  netLiquidationValue Decimal           @db.Decimal(20, 8)
  realizedPnl         Decimal           @db.Decimal(20, 8)
  unrealizedPnl       Decimal           @db.Decimal(20, 8)
  timestamp           DateTime
  sourceEventId       String
  createdAt           DateTime          @default(now())
  simulationAccount   SimulationAccount @relation(fields: [simulationAccountId], references: [id], onDelete: Restrict)
  sourceEvent         SimulatorEvent    @relation(fields: [sourceEventId], references: [id], onDelete: Restrict)

  @@unique([simulationAccountId, sourceEventId])
  @@index([simulationAccountId, timestamp])
}

model StrategyEvaluation {
  id                  String               @id
  strategyId          String
  strategyVersion     String
  evaluationTimestamp DateTime
  instrumentId        String
  symbol              String
  sessionState        MarketDataSessionState
  marketContext       Json
  portfolioContext    Json
  riskContext         Json
  dataTrust           Json
  inputReference      Json
  decisionState       StrategyDecisionState
  decisionReason      String
  signalSummary       Json
  guardrailSummary    Json
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tradeIntent         StrategyTradeIntent?

  @@index([strategyId, strategyVersion, evaluationTimestamp])
  @@index([instrumentId, evaluationTimestamp])
  @@index([decisionState, evaluationTimestamp])
}

model StrategyTradeIntent {
  id                    String             @id
  strategyEvaluationId  String             @unique
  strategyId            String
  strategyVersion       String
  evaluationCorrelationId String
  instrumentId          String
  symbol                String
  side                  SimulatedOrderSide
  requestedQuantity     Decimal            @db.Decimal(20, 8)
  orderType             SimulatedOrderType
  intentTimestamp       DateTime
  intentMetadata        Json
  createdAt             DateTime           @default(now())
  strategyEvaluation    StrategyEvaluation @relation(fields: [strategyEvaluationId], references: [id], onDelete: Restrict)

  @@index([strategyId, strategyVersion, intentTimestamp])
  @@index([instrumentId, intentTimestamp])
}
